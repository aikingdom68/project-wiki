{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Wiki Output Contract",
  "type": "object",
  "required": [
    "task_type",
    "verified_facts",
    "synthesis",
    "evidence",
    "gaps",
    "confidence"
  ],
  "properties": {
    "task_type": {
      "type": "string",
      "enum": [
        "explain",
        "evaluate",
        "compare",
        "decide",
        "build_wiki",
        "update_wiki",
        "source_guided_explain",
        "query"
      ]
    },
    "verified_facts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "synthesis": {
      "type": "array",
      "items": {"type": "string"}
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "why_it_matters"],
        "properties": {
          "source": {"type": "string"},
          "section_or_symbol": {"type": "string"},
          "why_it_matters": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "source_derived": {
      "type": "array",
      "items": {"type": "string"}
    },
    "local_supplement": {
      "type": "array",
      "items": {"type": "string"}
    },
    "general_supplement": {
      "type": "array",
      "items": {"type": "string"}
    },
    "conflicts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "gaps": {
      "type": "array",
      "items": {"type": "string"}
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "confidence_basis": {
      "type": "string"
    },
    "review_status": {
      "type": "string",
      "enum": ["draft", "reviewed", "needs_review", "archived"]
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "retention_class": {
      "type": "string",
      "enum": ["working", "reference", "historical", "ephemeral"]
    },
    "supersedes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "superseded_by": {
      "type": "array",
      "items": {"type": "string"}
    },
    "consolidation_status": {
      "type": "string",
      "enum": ["raw", "curated", "crystallized"]
    },
    "crystallized_from": {
      "type": "array",
      "items": {"type": "string"}
    },
    "comparison_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["option", "evidence"],
        "properties": {
          "option": {"type": "string"},
          "local_fit": {"type": "string"},
          "complexity": {"type": "string"},
          "maintainability": {"type": "string"},
          "performance": {"type": "string"},
          "evidence": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "recommendation": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "update_plan": {
      "type": "array",
      "items": {"type": "string"}
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "anchor_text", "source_path", "confidence"],
        "properties": {
          "id": {"type": "string"},
          "anchor_text": {"type": "string"},
          "source_id": {"type": "string"},
          "source_title": {"type": "string"},
          "source_path": {"type": "string"},
          "section_path": {"type": "string"},
          "snippet": {"type": "string"},
          "confidence": {
            "type": "string",
            "enum": ["verified_fact", "synthesis", "open_question"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["task_type"],
        "properties": {"task_type": {"const": "compare"}}
      },
      "then": {
        "required": ["comparison_matrix", "recommendation", "assumptions"]
      }
    },
    {
      "if": {
        "required": ["task_type"],
        "properties": {"task_type": {"const": "evaluate"}}
      },
      "then": {
        "required": ["recommendation", "assumptions"]
      }
    },
    {
      "if": {
        "required": ["task_type"],
        "properties": {"task_type": {"const": "build_wiki"}}
      },
      "then": {
        "required": ["update_plan"]
      }
    },
    {
      "if": {
        "required": ["task_type"],
        "properties": {"task_type": {"const": "update_wiki"}}
      },
      "then": {
        "required": ["update_plan"],
        "anyOf": [
          {"required": ["review_status"]},
          {"required": ["last_reviewed"]},
          {"required": ["retention_class"]},
          {"required": ["consolidation_status"]},
          {"required": ["supersedes"]},
          {"required": ["superseded_by"]},
          {"required": ["crystallized_from"]},
          {"required": ["confidence_basis"]}
        ]
      }
    },
    {
      "if": {
        "required": ["task_type"],
        "properties": {"task_type": {"const": "source_guided_explain"}}
      },
      "then": {
        "required": ["source_derived", "local_supplement", "general_supplement"]
      }
    },
    {
      "if": {
        "required": ["task_type"],
        "properties": {"task_type": {"const": "query"}}
      },
      "then": {
        "required": ["citations"]
      }
    }
  ]
}
