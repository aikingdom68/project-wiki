{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Wiki Output Contract",
  "type": "object",
  "required": [
    "task_type",
    "verified_facts",
    "synthesis",
    "evidence",
    "gaps",
    "confidence"
  ],
  "properties": {
    "task_type": {
      "type": "string",
      "enum": [
        "explain",
        "evaluate",
        "compare",
        "decide",
        "build_wiki",
        "update_wiki",
        "source_guided_explain"
      ]
    },
    "verified_facts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "synthesis": {
      "type": "array",
      "items": {"type": "string"}
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "why_it_matters"],
        "properties": {
          "source": {"type": "string"},
          "section_or_symbol": {"type": "string"},
          "why_it_matters": {"type": "string"}
        }
      }
    },
    "source_derived": {
      "type": "array",
      "items": {"type": "string"}
    },
    "local_supplement": {
      "type": "array",
      "items": {"type": "string"}
    },
    "general_supplement": {
      "type": "array",
      "items": {"type": "string"}
    },
    "conflicts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "gaps": {
      "type": "array",
      "items": {"type": "string"}
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "comparison_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["option", "evidence"],
        "properties": {
          "option": {"type": "string"},
          "local_fit": {"type": "string"},
          "complexity": {"type": "string"},
          "maintainability": {"type": "string"},
          "performance": {"type": "string"},
          "evidence": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "recommendation": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "update_plan": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"task_type": {"const": "compare"}}},
      "then": {
        "required": ["comparison_matrix", "recommendation", "assumptions"]
      }
    },
    {
      "if": {"properties": {"task_type": {"const": "evaluate"}}},
      "then": {
        "required": ["recommendation", "assumptions"]
      }
    },
    {
      "if": {"properties": {"task_type": {"const": "build_wiki"}}},
      "then": {
        "required": ["update_plan"]
      }
    },
    {
      "if": {"properties": {"task_type": {"const": "source_guided_explain"}}},
      "then": {
        "required": ["source_derived", "local_supplement", "general_supplement"]
      }
    }
  ]
}
